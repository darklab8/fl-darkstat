package front

import (
	"github.com/darklab8/fl-darkstat/darkcore/core_front"
	"github.com/darklab8/fl-darkstat/darkcore/core_static"
	"github.com/darklab8/fl-darkstat/darkmap/export_map"
	"github.com/darklab8/fl-darkstat/darkmap/front/static_front"
)

templ Html5() {
	<!DOCTYPE html>
	<html>
		<head>
			@core_front.StaticFile(static_front.FaviconIco)
			<title>{ "darkmap" }</title>
			@core_front.StaticFile(core_static.ResetCSS)
			@core_front.StaticFile(core_static.SortableJS)
			@core_front.StaticFile(core_static.HtmxJS)
			@core_front.StaticFile(core_static.HtmxPreloadJS)
			@core_front.StaticFile(static_front.CommonCSS)
			@core_front.StaticFile(static_front.CustomCSS)
			@core_front.StaticFile(static_front.GalaxyCSS)
			@core_front.StaticFile(static_front.PanzoomJS)
			@core_front.StaticFile(static_front.ZonesCSS)
			<script>
			</script>
			<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=yes"/>
		</head>
		<body class="zoomedOut">
			{ children... }
		</body>
	</html>
}

templ Index(data *export_map.Export) {
	@Html5() {
		@GalaxyGrid(MenuKindGalaxy) {
			@GalalaxyMap(data)
		}
	}
}
